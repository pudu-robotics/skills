                        "title": "循环次数"
                    },
                    "design_capacity": {
                        "type": "integer",
                        "format": "int32",
                        "title": "设计容量,单位 mAH"
                    },
                    "pack_voltage": {
                        "type": "integer",
                        "format": "int32",
                        "title": "电压,单位 mV"
                    },
                    "soc": {
                        "type": "integer",
                        "format": "int32",
                        "title": "电量,单位 %"
                    },
                    "soh": {
                        "type": "integer",
                        "format": "int32",
                        "title": "健康指数,单位 %"
                    },
                    "full_capacity": {
                        "type": "integer",
                        "format": "int32",
                        "title": "满充容量,单位 mAH"
                    },
                    "work_status": {
                        "type": "integer",
                        "format": "int32",
                        "title": "电池工作状态 0:放电状态 1:充电状态 2:休眠状态 3:关机状态 0xFF:故障状态"
                    },
                    "current": {
                        "type": "integer",
                        "format": "int32",
                        "title": "电流: >0 在充电, <=0 在放电, 单位mA"
