{
    "openapi": "3.0.0",
    "info": {
        "title": "open/analysis_industry.proto",
        "version": "version not set"
    },
    "tags": [
        {
            "name": "OpenDataAnalysisIndustry"
        }
    ],
    "paths": {
        "/data-board/v1/analysis/task/lifting": {
            "get": {
                "summary": "机器人工业数据 - 顶升Tab+Graph",
                "operationId": "OpenDataAnalysisIndustry_AnalysisTaskLifting",
                "responses": {
                    "200": {
                        "description": "A successful response.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/openAnalysisTaskLiftingRsp"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "An unexpected error response.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/rpcStatus"
                                }
                            }
                        }
                    }
                },
                "parameters": [
                    {
                        "name": "timezone_offset",
                        "description": "时区偏移小时, 范围 -12 ~ 14，表示 (UTC-12 ~ UTC+14）；默认UTC+8.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    },
                    {
                        "name": "start_time",
                        "description": "开始时间戳(s).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "end_time",
                        "description": "结束时间戳(s).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "shop_id",
                        "description": "门店ID过滤.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "time_unit",
                        "description": "时间单位：day | hour，表示 按天|按小时; 默认值：day(时间跨度>24小时) ，hour(时间跨度<24小时).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "tags": [
                    "OpenDataAnalysisIndustry"
                ]
            }
        },
        "/data-board/v1/analysis/task/lifting/paging": {
            "get": {
                "summary": "机器人工业数据 - 顶升(分页)",
                "operationId": "OpenDataAnalysisIndustry_AnalysisTaskLiftingPaging",
                "responses": {
                    "200": {
                        "description": "A successful response.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/openAnalysisTaskLiftingPagingRsp"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "An unexpected error response.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/rpcStatus"
                                }
                            }
                        }
                    }
                },
                "parameters": [
                    {
                        "name": "timezone_offset",
                        "description": "时区偏移小时, 范围 -12 ~ 14，表示 (UTC-12 ~ UTC+14）；默认UTC+8.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    },
                    {
                        "name": "start_time",
                        "description": "开始时间戳(s).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "end_time",
                        "description": "结束时间戳(s).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "shop_id",
                        "description": "门店ID过滤.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "time_unit",
                        "description": "时间单位：day | hour | all, 表示 按天|按小时|汇总(仅门店分组有效); 默认值：day(时间跨度>24小时) ，hour(时间跨度<24小时).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "limit",
                        "description": "每页条目数，1 ~ 20, 默认10.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    },
                    {
                        "name": "offset",
                        "description": "偏移量, 从0开始.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    },
                    {
                        "name": "group_by",
                        "description": "分组方式：robot | shop，表示 按机器 | 按门店.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "tags": [
                    "OpenDataAnalysisIndustry"
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "AnalysisTaskLiftingPagingRspListItem": {
                "type": "object",
                "properties": {
                    "task_time": {
                        "type": "string",
                        "title": "任务结束时归属时段（hour时用Y-m-d H:i:s时间，day时用Y-m-d日期，all时无此字段）"
                    },
                    "mac": {
                        "type": "string",
                        "title": "MAC；注：按机器分组时有效"
                    },
                    "shop_id": {
                        "type": "integer",
                        "format": "int64",
                        "title": "门店ID"
                    },
                    "shop_name": {
                        "type": "string",
                        "title": "门店名称"
                    },
                    "product_code": {
                        "type": "string",
                        "title": "产品枚举；注：按机器分组时有效"
                    },
                    "mileage": {
                        "type": "number",
                        "format": "double",
                        "title": "运行里程(km)"
                    },
                    "duration": {
                        "type": "number",
                        "format": "double",
                        "title": "运行时长(h)"
                    },
                    "destination_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "运货次数"
                    },
                    "sn": {
                        "type": "string",
                        "title": "设备SN；注：按机器分组时有效"
                    },
                    "task_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "任务数"
                    },
                    "speed": {
                        "type": "number",
                        "format": "double",
                        "title": "平均速度m/s"
                    },
                    "run_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "运行机器人数；注：按门店分组时有效"
                    },
                    "bind_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "绑定机器人数；注：按门店分组时有效"
                    },
                    "robot_name": {
                        "type": "string",
                        "title": "机器人昵称"
                    },
                    "work_days": {
                        "type": "integer",
                        "format": "int32",
                        "title": "工作天数(仅all汇总时有效)"
                    }
                }
            },
            "AnalysisTaskLiftingRspChartItem": {
                "type": "object",
                "properties": {
                    "task_time": {
                        "type": "string",
                        "title": "横坐标时间（hour时用0-24小时，day时用Y-m-d日期）"
                    },
                    "mileage": {
                        "type": "number",
                        "format": "double",
                        "title": "运行里程(km)"
                    },
                    "duration": {
                        "type": "number",
                        "format": "double",
                        "title": "运行时长(h)"
                    },
                    "destination_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "运货次数"
                    },
                    "task_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "任务数"
                    },
                    "speed": {
                        "type": "number",
                        "format": "double",
                        "title": "平均速度m/s"
                    }
                }
            },
            "AnalysisTaskLiftingRspSummary": {
                "type": "object",
                "properties": {
                    "mileage": {
                        "type": "number",
                        "format": "double",
                        "title": "运行里程(km)"
                    },
                    "duration": {
                        "type": "number",
                        "format": "double",
                        "title": "运行时长(h)"
                    },
                    "destination_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "运货次数"
                    },
                    "task_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "任务数"
                    },
                    "speed": {
                        "type": "number",
                        "format": "double",
                        "title": "平均速度m/s"
                    }
                }
            },
            "openAnalysisTaskLiftingPagingRsp": {
                "type": "object",
                "properties": {
                    "code": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "$ref": "#/components/schemas/openAnalysisTaskLiftingPagingRspData"
                    }
                }
            },
            "openAnalysisTaskLiftingPagingRspData": {
                "type": "object",
                "properties": {
                    "total": {
                        "type": "integer",
                        "format": "int32",
                        "title": "总条目数"
                    },
                    "offset": {
                        "type": "integer",
                        "format": "int32",
                        "title": "偏移量"
                    },
                    "limit": {
                        "type": "integer",
                        "format": "int32",
                        "title": "每页条目数"
                    },
                    "list": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/AnalysisTaskLiftingPagingRspListItem"
                        },
                        "title": "当前页详细数据"
                    }
                }
            },
            "openAnalysisTaskLiftingRsp": {
                "type": "object",
                "properties": {
                    "code": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "$ref": "#/components/schemas/openAnalysisTaskLiftingRspData"
                    }
                }
            },
            "openAnalysisTaskLiftingRspData": {
                "type": "object",
                "properties": {
                    "summary": {
                        "$ref": "#/components/schemas/AnalysisTaskLiftingRspSummary"
                    },
                    "qoq": {
                        "$ref": "#/components/schemas/AnalysisTaskLiftingRspSummary"
                    },
                    "chart": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/AnalysisTaskLiftingRspChartItem"
                        },
                        "title": "折线图的数据"
                    },
                    "qoq_chart": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/AnalysisTaskLiftingRspChartItem"
                        },
                        "title": "环比折线图的数据"
                    }
                }
            },
            "protobufAny": {
                "type": "object",
                "properties": {
                    "@type": {
                        "type": "string"
                    }
                },
                "additionalProperties": {}
            },
            "rpcStatus": {
                "type": "object",
                "properties": {
                    "code": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "message": {
                        "type": "string"
                    },
                    "details": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/protobufAny"
                        }
                    }
                }
            }
        }
    }
}