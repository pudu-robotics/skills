    "paths": {
        "/data-board/v1/analysis/run": {
            "get": {
                "summary": "机器人运行分析",
                "operationId": "OpenDataAnalysisCommon_AnalysisRun",
                "responses": {
                    "200": {
                        "description": "A successful response.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/openAnalysisRunRsp"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "An unexpected error response.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/rpcStatus"
                                }
                            }
                        }
                    }
                },
                "parameters": [
                    {
                        "name": "timezone_offset",
                        "description": "时区偏移小时, 范围 -12 ~ 14，表示 (UTC-12 ~ UTC+14）；默认UTC+8.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    },
                    {
                        "name": "start_time",
                        "description": "开始时间戳(s).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "end_time",
                        "description": "结束时间戳(s).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "shop_id",
                        "description": "门店ID过滤.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "time_unit",
                        "description": "时间单位：day | hour，表示 按天|按小时; 默认值：day(时间跨度>24小时) ，hour(时间跨度<24小时).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "tags": [
                    "OpenDataAnalysisCommon"
                ]
            }
        },
