            }
        },
        "/data-board/v1/analysis/clean/paging": {
            "get": {
                "summary": "机器人清洁数据 - 洗地|扫地模式(分页)",
                "operationId": "OpenDataAnalysisClean_AnalysisCleanPaging",
                "responses": {
                    "200": {
                        "description": "A successful response.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/openAnalysisCleanPagingRsp"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "An unexpected error response.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/rpcStatus"
                                }
                            }
                        }
                    }
                },
                "parameters": [
                    {
                        "name": "timezone_offset",
                        "description": "时区偏移小时, 范围 -12 ~ 14，表示 (UTC-12 ~ UTC+14）；默认UTC+8.",
                        "in": "query",
                        "required": false,
