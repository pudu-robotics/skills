                ]
            }
        }
    },
    "components": {
        "schemas": {
            "openAnalysisCleanDetailRsp": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string"
                    },
                    "chart": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/openAnalysisCleanDetailRspChartItem"
                        }
                    }
                },
                "title": "出参:清洁任务运行分布"
            },
            "openAnalysisCleanDetailRspChartItem": {
                "type": "object",
                "properties": {
                    "task_time": {
                        "type": "string",
                        "title": "横坐标时间（H:i:s）"
                    },
                    "running_task_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "任务的个数"
                    }
                }
            },
            "openAnalysisCleanModeRsp": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "$ref": "#/components/schemas/openAnalysisCleanModeRspData"
                    }
                },
                "title": "出参:洗地|扫地模式"
            },
            "openAnalysisCleanModeRspChartItem": {
                "type": "object",
                "properties": {
                    "task_time": {
                        "type": "string",
                        "title": "横坐标时间（hour时用0-24小时，day时用Y-m-d日期）"
                    },
                    "area": {
                        "type": "number",
                        "format": "double",
                        "title": "清洁面积(m²)"
                    },
                    "duration": {
                        "type": "number",
                        "format": "double",
                        "title": "清洁时长(h)"
                    },
                    "power_consumption": {
                        "type": "number",
                        "format": "double",
                        "title": "耗电情况(Kw/h)"
                    },
                    "water_consumption": {
                        "type": "number",
                        "format": "double",
                        "title": "耗水情况(ML)"
                    },
                    "task_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "清洁任务数"
                    },
                    "plan_area": {
                        "type": "number",
                        "format": "double",
                        "title": "计划清洁面积(m²)"
                    }
                }
            },
            "openAnalysisCleanModeRspData": {
                "type": "object",
                "properties": {
                    "summary": {
                        "$ref": "#/components/schemas/openAnalysisCleanModeRspItem"
                    },
                    "qoq": {
                        "$ref": "#/components/schemas/openAnalysisCleanModeRspItem"
                    },
                    "chart": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/openAnalysisCleanModeRspChartItem"
                        },
                        "title": "折线图的数据"
                    },
                    "qoq_chart": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/openAnalysisCleanModeRspChartItem"
                        },
                        "title": "环比折线图的数据"
                    }
                }
            },
            "openAnalysisCleanModeRspItem": {
                "type": "object",
                "properties": {
                    "area": {
                        "type": "number",
                        "format": "double",
                        "title": "清洁面积(m²)"
                    },
                    "duration": {
                        "type": "number",
                        "format": "double",
                        "title": "清洁时长(h)"
                    },
                    "power_consumption": {
                        "type": "number",
                        "format": "double",
                        "title": "耗电情况(Kw/h)"
                    },
                    "water_consumption": {
                        "type": "number",
                        "format": "double",
                        "title": "耗水情况(ML)"
                    },
                    "task_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "清洁任务数"
                    },
                    "plan_area": {
                        "type": "number",
                        "format": "double",
                        "title": "计划清洁面积(m²)"
                    }
                }
            },
            "openAnalysisCleanPagingRsp": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "$ref": "#/components/schemas/openAnalysisCleanPagingRspData"
                    }
                },
                "title": "出参:洗地|扫地模式(分页)"
            },
            "openAnalysisCleanPagingRspData": {
                "type": "object",
                "properties": {
                    "total": {
                        "type": "integer",
                        "format": "int32",
                        "title": "总条目数"
                    },
                    "offset": {
                        "type": "integer",
                        "format": "int32",
                        "title": "偏移量"
                    },
                    "limit": {
                        "type": "integer",
                        "format": "int32",
                        "title": "每页条目数"
                    },
                    "list": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/openAnalysisCleanPagingRspItem"
                        },
                        "title": "当前页详细数据"
                    }
                }
            },
            "openAnalysisCleanPagingRspItem": {
                "type": "object",
                "properties": {
                    "task_time": {
                        "type": "string",
                        "title": "任务结束时归属时段（hour时用Y-m-d H:i:s时间，day时用Y-m-d日期，all时无此字段）"
                    },
                    "mac": {
                        "type": "string",
                        "title": "MAC"
                    },
                    "shop_id": {
                        "type": "integer",
                        "format": "int64",
                        "title": "门店ID"
                    },
                    "shop_name": {
                        "type": "string",
                        "title": "门店名称"
                    },
                    "product_code": {
                        "type": "string",
                        "title": "产品枚举；注：按机器分组时有效"
                    },
                    "area": {
                        "type": "number",
                        "format": "double",
                        "title": "清洁面积(m²)"
                    },
                    "duration": {
                        "type": "number",
                        "format": "double",
                        "title": "清洁时长"
                    },
                    "sn": {
                        "type": "string",
                        "title": "设备SN；注：按机器分组时有效"
                    },
                    "run_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "运行机器人数；注：按门店分组时有效"
                    },
                    "bind_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "绑定机器人数；注：按门店分组时有效"
                    },
                    "power_consumption": {
                        "type": "number",
                        "format": "double",
                        "title": "耗电量（kw/h）"
                    },
                    "water_consumption": {
                        "type": "number",
                        "format": "double",
                        "title": "耗水量（ML）"
                    },
                    "task_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "任务数"
                    },
                    "robot_name": {
                        "type": "string",
                        "title": "机器人昵称"
                    },
                    "plan_area": {
                        "type": "number",
                        "format": "double",
                        "title": "计划清洁面积(m²)"
                    },
                    "work_days": {
                        "type": "integer",
                        "format": "int32",
                        "title": "工作天数(仅all汇总时有效)"
                    }
                }
            },
            "protobufAny": {
                "type": "object",
                "properties": {
                    "@type": {
                        "type": "string"
                    }
                },
                "additionalProperties": {}
            },
            "rpcStatus": {
                "type": "object",
                "properties": {
                    "code": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "message": {
                        "type": "string"
                    },
                    "details": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/protobufAny"
                        }
                    }
                }
            }
        }
    }
}