                    },
                    {
                        "name": "start_time",
                        "description": "开始时间戳(s).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "end_time",
                        "description": "结束时间戳(s).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "shop_id",
                        "description": "门店ID过滤.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "time_unit",
                        "description": "时间单位：day | hour，表示 按天|按小时; 默认值：day(时间跨度>24小时) ，hour(时间跨度<24小时).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "clean_mode",
                        "description": "清洁模式过滤（0全部，1洗地，2扫地）.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    },
                    {
                        "name": "sub_mode",
                        "description": "子模式过滤(-1全部 扫地[0自定义 1地毯吸尘 3静音尘推] 洗地[0自定义 1吸力模式 11重污 12标准 13节能 14少水渍 15浸泡 16吸水 17强刷 18配件 19配件节能]).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    },
                    {
                        "name": "group_by",
                        "description": "分组方式：robot | shop，表示 按机器 | 按门店.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "limit",
                        "description": "每页条目数，1 ~ 20, 默认10.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    },
                    {
                        "name": "offset",
                        "description": "偏移量, 从0开始.",
                        "in": "query",
