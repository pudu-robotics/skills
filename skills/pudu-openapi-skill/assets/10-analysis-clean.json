{
    "openapi": "3.0.0",
    "info": {
        "title": "open/analysis_clean.proto",
        "version": "version not set"
    },
    "tags": [
        {
            "name": "OpenDataAnalysisClean"
        }
    ],
    "paths": {
        "/data-board/v1/analysis/clean/detail": {
            "get": {
                "summary": "机器人清洁数据 - 洗地|扫地模式(清洁任务运行分布)",
                "operationId": "OpenDataAnalysisClean_AnalysisCleanDetail",
                "responses": {
                    "200": {
                        "description": "A successful response.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/openAnalysisCleanDetailRsp"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "An unexpected error response.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/rpcStatus"
                                }
                            }
                        }
                    }
                },
                "parameters": [
                    {
                        "name": "timezone_offset",
                        "description": "时区偏移小时, 范围 -12 ~ 14，表示 (UTC-12 ~ UTC+14）；默认UTC+8.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    },
                    {
                        "name": "start_time",
                        "description": "开始时间戳(s).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "end_time",
                        "description": "结束时间戳(s).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "shop_id",
                        "description": "门店ID过滤.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "clean_mode",
                        "description": "清洁模式过滤（0全部，1洗地，2扫地）.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    },
                    {
                        "name": "sub_mode",
                        "description": "子模式过滤(-1全部 扫地[0自定义 1地毯吸尘 3静音尘推] 洗地[0自定义 1吸力模式 11重污 12标准 13节能 14少水渍 15浸泡 16吸水 17强刷 18配件 19配件节能]).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    }
                ],
                "tags": [
                    "OpenDataAnalysisClean"
                ]
            }
        },
        "/data-board/v1/analysis/clean/mode": {
