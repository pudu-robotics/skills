                    },
                    {
                        "name": "time_unit",
                        "description": "时间单位：day | hour，表示 按天|按小时; 默认值：day(时间跨度>24小时) ，hour(时间跨度<24小时).",
                        "in": "query",
                        "required": false,
                        "schema": {
