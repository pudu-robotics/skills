        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpenAPIGetMapGroupReply"
                }
              }
            }
          },
          "default": {
            "description": "Default error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/map-service/v1/open/image": {
      "post": {
        "tags": [
          "MapRestful"
        ],
        "description": "OpenGetMapImage,获取地图底图信息,复用内部接口GetMapImage",
        "operationId": "MapRestful_OpenGetMapImage",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OpenGetMapImageReq"
              }
