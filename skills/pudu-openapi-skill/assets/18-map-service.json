          },
          "limit": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "OpenAPIGetCurrentMapReply": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/OpenAPIGetCurrentMapReply_MapInfo"
          }
