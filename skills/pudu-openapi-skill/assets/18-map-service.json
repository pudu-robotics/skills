          },
          "default": {
            "description": "Default error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GetOpenMapRsp": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/GetOpenMap_Data"
          }
        }
      },
      "OpenAPIGetCurrentMapPointReply": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/OpenAPIGetCurrentMapPointReply_Data"
          }
        }
      },
      "OpenAPIGetCurrentMapPointReq": {
        "type": "object",
        "properties": {
          "sn": {
            "type": "string"
          },
