{
  "openapi": "3.0.3",
  "info": {
    "title": "MapRestful - 地图服务",
    "version": "0.0.1"
  },
  "paths": {
    "/map-service/v1/open/current": {
      "get": {
        "tags": [
          "MapRestful"
        ],
        "description": "开放平台获取机器当前使用地图",
        "operationId": "MapRestful_OpenAPIGetCurrentMap",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OpenAPIGetCurrentMapReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpenAPIGetCurrentMapReply"
                }
              }
            }
          },
          "default": {
            "description": "Default error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/map-service/v1/open/group": {
      "post": {
        "tags": [
          "MapRestful"
        ],
        "description": "获取某张地图的点位分组",
        "operationId": "MapRestful_OpenAPIGetMapGroup",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OpenAPIGetMapGroupReq"
              }
            }
          },
          "required": true
