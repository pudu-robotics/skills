            "type": "string"
          }
        }
      },
      "OpenAPIGetMapListReply": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/OpenAPIGetMapListReply_Data"
          }
        }
      },
      "OpenAPIGetMapListReq": {
        "type": "object",
        "properties": {
          "sn": {
            "type": "string"
          }
        }
      },
      "OpenGetMapImageReply": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/OpenGetMapImageReply_Data"
          }
        }
      },
      "OpenGetMapImageReq": {
        "type": "object",
        "properties": {
