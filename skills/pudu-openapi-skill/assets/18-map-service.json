          },
          "default": {
            "description": "Default error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/map-service/v1/open/list": {
      "get": {
        "tags": [
          "MapRestful"
        ],
        "description": "开放平台获取地图列表",
        "operationId": "MapRestful_OpenAPIGetMapList",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OpenAPIGetMapListReq"
