              }
            }
          },
          "default": {
            "description": "Default error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/map-service/v1/open/map": {
      "get": {
        "tags": [
          "MapRestful"
        ],
        "description": "获取地图详情",
        "operationId": "MapRestful_GetOpenMap",
        "parameters": [
          {
            "name": "shopId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "mapName",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetOpenMapRsp"
                }
              }
            }
          },
          "default": {
            "description": "Default error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/map-service/v1/open/point": {
      "get": {
        "tags": [
          "MapRestful"
        ],
        "description": "开放平台获取机器当前使用地图的点位信息",
