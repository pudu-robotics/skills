    "components": {
        "schemas": {
            "BriefShopRspTopItem": {
                "type": "object",
                "properties": {
                    "shop_id": {
                        "type": "integer",
                        "format": "int64",
                        "title": "门店ID"
                    },
                    "shop_name": {
                        "type": "string",
                        "title": "门店名称"
                    },
                    "run_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "运行机器人数"
                    },
                    "bind_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "绑定机器人数"
                    },
                    "duration": {
                        "type": "number",
                        "format": "double",
                        "title": "运行时长(h)"
                    },
                    "stop_duration": {
                        "type": "number",
                        "format": "double",
                        "title": "停运时长(h)"
                    }
                }
            },
            "openBriefRobotRsp": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string"
                    },
                    "data": {
