                        "title": "饼图的数据"
                    }
                }
            },
            "openBriefRobotRspItem": {
                "type": "object",
                "properties": {
                    "boot_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "开机机器数"
                    },
                    "total_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "累计机器数"
                    },
                    "bind_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "绑定机器数"
                    },
                    "active_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "激活机器数"
                    },
                    "lively_rate": {
                        "type": "number",
                        "format": "double",
                        "title": "活跃率(开机机器数/累计机器数)"
                    }
                }
            },
            "openBriefRunRsp": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "$ref": "#/components/schemas/openBriefRunRspData"
                    }
                },
                "title": "出参:机器运行概览"
            },
            "openBriefRunRspData": {
                "type": "object",
                "properties": {
                    "summary": {
                        "$ref": "#/components/schemas/openBriefRunRspItem"
                    },
                    "qoq": {
                        "$ref": "#/components/schemas/openBriefRunRspItem"
                    }
                }
            },
            "openBriefRunRspItem": {
                "type": "object",
                "properties": {
                    "duration": {
                        "type": "number",
                        "format": "double",
                        "title": "工作时长(h)"
                    },
                    "mileage": {
                        "type": "number",
                        "format": "double",
                        "title": "运行里程(km)"
                    },
                    "task_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "执行任务次数"
                    },
                    "area": {
                        "type": "number",
                        "format": "double",
                        "title": "清洁面积(m²)"
                    }
