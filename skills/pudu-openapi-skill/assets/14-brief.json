                    },
                    "bind_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "绑定机器数"
                    },
                    "active_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "激活机器数"
                    },
                    "bind_rate": {
                        "type": "number",
                        "format": "double",
                        "title": "绑定占比"
                    },
                    "active_rate": {
                        "type": "number",
                        "format": "double",
                        "title": "激活占比"
                    }
                }
            },
            "openBriefRobotRspData": {
                "type": "object",
                "properties": {
                    "summary": {
                        "$ref": "#/components/schemas/openBriefRobotRspItem"
                    },
                    "qoq": {
                        "$ref": "#/components/schemas/openBriefRobotRspItem"
                    },
                    "chart": {
                        "type": "object",
                        "additionalProperties": {
                            "$ref": "#/components/schemas/openBriefRobotRspChartItem"
