{
    "openapi": "3.0.0",
    "info": {
        "title": "open/brief.proto",
        "version": "version not set"
    },
    "tags": [
        {
            "name": "OpenDataBrief"
        }
    ],
    "paths": {
        "/data-board/v1/brief/robot": {
            "get": {
                "summary": "机器概览",
                "operationId": "OpenDataBrief_BriefRobot",
                "responses": {
                    "200": {
                        "description": "A successful response.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/openBriefRobotRsp"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "An unexpected error response.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/rpcStatus"
                                }
                            }
                        }
                    }
                },
                "parameters": [
                    {
                        "name": "timezone_offset",
                        "description": "时区偏移小时, 范围 -12 ~ 14，表示 (UTC-12 ~ UTC+14）；默认UTC+8.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    },
                    {
                        "name": "start_time",
                        "description": "开始时间戳(s).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "end_time",
                        "description": "结束时间戳(s).",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "shop_id",
                        "description": "门店ID过滤.",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "tags": [
                    "OpenDataBrief"
                ]
            }
        },
