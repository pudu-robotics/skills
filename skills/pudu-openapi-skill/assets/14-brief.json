                    "new_count": {
                        "type": "integer",
                        "format": "int32",
                        "title": "新增门店数"
                    },
                    "lively_rate": {
                        "type": "number",
                        "format": "double",
                        "title": "活跃率(活跃门店数/累计门店数)"
                    }
                }
            },
            "protobufAny": {
                "type": "object",
                "properties": {
                    "@type": {
                        "type": "string"
                    }
                },
                "additionalProperties": {}
            },
            "rpcStatus": {
                "type": "object",
                "properties": {
                    "code": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "message": {
                        "type": "string"
                    },
                    "details": {
                        "type": "array",
                        "items": {
