{
  "openapi": "3.0.3",
  "info": {
    "title": "CloudOpenApi - 机器避险",
    "version": "0.0.1"
  },
  "paths": {
    "/open-platform-service/v1/disaster/evacuate": {
      "post": {
        "tags": [
          "CloudOpenApi"
        ],
        "description": "向机器人组下发灾害避险任务",
        "operationId": "CloudOpenApi_DisasterEvacuate",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DisasterEvacuateReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DisasterEvacuateRsp"
                }
              }
            }
          },
          "default": {
            "description": "Default error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/open-platform-service/v1/disaster/cancel": {
      "post": {
        "tags": [
          "CloudOpenApi"
        ],
        "description": "解除/取消已下发的灾害避险任务",
        "operationId": "CloudOpenApi_DisasterCancel",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DisasterEvacuateReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DisasterEvacuateRsp"
                }
              }
            }
          },
          "default": {
            "description": "Default error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DisasterEvacuateReq": {
        "type": "object",
        "required": [
          "shop_id"
        ],
        "properties": {
          "shop_id": {
            "type": "integer",
            "format": "int32",
            "description": "门店 ID"
          },
          "group_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "机器分组 ID 列表"
          }
        }
      },
      "DisasterEvacuateRsp": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/DisasterEvacuateData"
          }
        }
      },
      "DisasterEvacuateData": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "description": "当 SUCCESS 时返回任务 id"
          },
          "invalid_groups": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "当 message=CLOUD_OPEN_INVALID_GROUP 时表示无效分组列表"
          }
        }
      },
      "Status": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "The status code, which should be an enum value of [google.rpc.Code][google.rpc.Code].",
            "format": "int32"
          },
          "message": {
            "type": "string",
            "description": "A developer-facing error message, which should be in English. Any user-facing error message should be localized and sent in the [google.rpc.Status.details][google.rpc.Status.details] field, or localized by the client."
          },
          "details": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GoogleProtobufAny"
            },
            "description": "A list of messages that carry the error details.  There is a common set of message types for APIs to use."
          }
        },
        "description": "The `Status` type defines a logical error model that is suitable for different programming environments, including REST APIs and RPC APIs. It is used by [gRPC](https://github.com/grpc). Each `Status` message contains three pieces of data: error code, error message, and error details. You can find out more about this error model and how to work with it in the [API Design Guide](https://cloud.google.com/apis/design/errors)."
      },
      "GoogleProtobufAny": {
        "type": "object",
        "properties": {
          "@type": {
            "type": "string",
            "description": "The type of the serialized message."
          }
        },
        "additionalProperties": true,
        "description": "Contains an arbitrary serialized message along with a @type that describes the type of the serialized message."
      }
    }
  }
}
